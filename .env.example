# Tech Radar Scanner — environment template.
# Copy to `.env` (gitignored) and fill in. NEVER commit the real .env.

# --- Nerdware Forge gateway (the scanner's LLM provider) ---
# OpenAI-compatible endpoint; key is the technical-user key in sk-... format.
FORGE_API_KEY=
FORGE_BASE_URL=https://forge.nerdware.ai/v1

# GitHub token with org repo-read scope.
# Leave blank locally and run: GH_TOKEN=$(gh auth token) npm run scan
GH_TOKEN=
